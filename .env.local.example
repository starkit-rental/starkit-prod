NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_ENV=development

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# KEEP SECRET — server-side only, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
# KEEP SECRET — server-side only
STRIPE_SECRET_KEY=sk_live_...
# Get from: https://dashboard.stripe.com/webhooks — after creating a webhook endpoint
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Resend Email ──────────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxx
RESEND_AUDIENCE_ID=
# Email address that receives admin order notifications
ADMIN_EMAIL=admin@example.com

# ── Cloudflare Turnstile (bot protection) ─────────────────────────────────────
# Get from: https://dash.cloudflare.com → Turnstile
# NEXT_PUBLIC_TURNSTILE_SITE_KEY is used on the frontend (safe to expose)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# KEEP SECRET — server-side verification only
TURNSTILE_SECRET_KEY=

# ── Sanity CMS ────────────────────────────────────────────────────────────────
# Use current date (YYYY-MM-DD) to target the latest API version
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-18
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=development
# KEEP SECRET — server-side only read token
SANITY_API_READ_TOKEN=

# ── Upstash Redis (persistent rate limiting — recommended for production) ─────
# Create a free database at https://console.upstash.com/
# Without these the app falls back to in-memory rate limiting (resets on cold start)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ── InPost GeoWidget ──────────────────────────────────────────────────────────
# Token from InPost Manager (https://manager.paczkomaty.pl)
# Restrict this token to your domain in InPost Manager
NEXT_PUBLIC_INPOST_GEOWIDGET_TOKEN=your_inpost_token_here